# Shared secret for the Operator cron endpoints (auth on /api/operators/*).
# Set the same value in (1) Vercel env vars and (2) the GitHub repo's Actions
# secrets as CRON_SECRET. Generate something long and random:
#   node -e "console.log(crypto.randomBytes(32).toString('hex'))"
